DATABASE_URL="postgresql://derek:password@192.168.0.2:5432/AgentStudio"
OPENROUTER_API_KEY="sk-or-v1-your-key"
AUTH_PASSWORD="change-me"
# Dev-only: when set to 1 AND NODE_ENV != 'production', requests without a session
# auto-attach to the singleton user (skips the /login redirect). For local dev when
# you've lost the password or are driving the app from a viewer that can't set
# cookies. Hard-disabled in production builds; never enable on a shared machine.
AUTH_DEV_BYPASS=0
SEARXNG_URL="http://192.168.0.2:8070"
SEARXNG_PASSWORD="change-me"
SANDBOX_WORKSPACE="/workspace"
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
APP_ENCRYPTION_KEY="change-me-32-bytes-min"
GITHUB_OAUTH_CLIENT_ID="your-github-client-id"
GITHUB_OAUTH_CLIENT_SECRET="your-github-client-secret"
AZURE_DEVOPS_OAUTH_CLIENT_ID="your-azure-devops-app-id"
AZURE_DEVOPS_OAUTH_CLIENT_SECRET="your-azure-devops-client-secret"
# AZURE_DEVOPS_OAUTH_CALLBACK_URL="https://your-host/source-control/azure-devops/callback"  # set when behind a reverse proxy
