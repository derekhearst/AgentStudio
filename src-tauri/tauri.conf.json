{
	"productName": "DrokBot",
	"version": "0.1.0",
	"identifier": "com.drokbot.app",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"fullscreen": false,
				"height": 900,
				"resizable": true,
				"title": "DrokBot",
				"width": 1200
			}
		],
		"security": {
			"csp": null
		}
	},
	"android": {
		"useWebKit": true,
		"minSdkVersion": 24,
		"targetSdkVersion": 34
	},
	"bundle": {
		"active": true,
		"targets": ["exe", "appimage"],
		"externalBin": [],
		"icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
		"resources": [],
		"copyright": ""
	}
}
